-- 02_stages.sql.template
-- Template: environment-specific external stage definition
-- This script defines an external stage pointing to an Azure Blob container.
-- Credentials (e.g. SAS token) must be configured locally before execution.

CREATE OR REPLACE STAGE stg_azure_raw
  URL='azure://<storage-account>.blob.core.windows.net/cultivate/'
  CREDENTIALS=(AZURE_SAS_TOKEN='<sas-token>');

-- Quick visibility check
LIST @stg_azure_raw;
