# CULTIVATE Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_SCHEMA=

# Azure Blob Storage (used by infra/azure/azure_blob_sync.py)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_CONTAINER_NAME=cultivatedata
AZURE_LOCAL_SYNC_DIR=./data_azure_sync

# LLM API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Custom Search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
